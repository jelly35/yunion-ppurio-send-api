# Google Apps Script → 서버 인증용 API 키
GOOGLE_APP_SCRIPT_API_KEY=your_google_app_script_api_key_here

# 뿌리오 API 설정
PPURIO_API_KEY=your_ppurio_api_key_here
PPURIO_ACCOUNT=your_ppurio_account
SENDER_PROFILE=@your_sender_profile

# Slack Webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# 서버 설정
SERVER_PORT=5000
